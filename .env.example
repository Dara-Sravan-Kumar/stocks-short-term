# Copy to .env and fill in your values (never commit .env)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PICKS_CHANNEL_ID=123456789012345678
# Optional: separate channel for holdings report (defaults to picks channel)
DISCORD_HOLDINGS_CHANNEL_ID=
# Optional: separate channel for paper-trading alerts (defaults to picks channel)
DISCORD_PAPER_CHANNEL_ID=

# OpenAlgo bridge for real INDmoney holdings sync (leave empty to use mock holdings)
# host of your locally running OpenAlgo server, e.g. http://127.0.0.1:5000
OPENALGO_HOST=
# API key generated in the OpenAlgo web UI
OPENALGO_API_KEY=

# Fyers API v3 (primary broker: market data + holdings; data APIs are free).
# Create an app at https://myapi.fyers.in, fill these in, then run
# `python fyers_login.py` once to authorize (again every ~15 days when the
# refresh token expires). PIN is your 4-digit Fyers login PIN (enables the
# daily access-token auto-refresh).
FYERS_APP_ID=
FYERS_SECRET_ID=
FYERS_PIN=
# Only set if your Fyers app uses a custom redirect URL:
FYERS_REDIRECT_URI=
# Shared token cache. The Fyers app is shared with mcx-short-term and Fyers
# keeps ONE active token per app - point BOTH projects' .env at the SAME file:
FYERS_TOKEN_PATH=C:/Users/srava/.fyers/fyers_token.json

# Trading mode: PAPER (default, virtual book only) or LIVE (mirror every paper
# entry/exit into a REAL Fyers order). LIVE additionally requires
# PLACE_ORDER_ENABLED=True in config.py - both gates must be flipped on purpose.
TRADING_MODE=PAPER
